# Dockerfile.arm64
FROM arm64v8/ros:jazzy AS builder

WORKDIR /root/ws

RUN if id -u 1000; then userdel `id -un 1000` ; fi

RUN apt-get update && apt-get upgrade -y \
    && apt-get install -y \
    git \
    build-essential \
    python3-pip \
    python3-rosdep \
    python3-colcon-common-extensions \
    python3-serial \
    python3-yaml \
    ros-jazzy-rviz2 \
    ros-jazzy-dynamixel-sdk

RUN mkdir -p src

COPY src src

RUN . /opt/ros/jazzy/setup.sh && \
    colcon build --packages-select gar_interfaces gar_gauge_control

RUN tar -czf install.tar.gz install

# Export only the install folder
FROM scratch

COPY --from=builder root/ws/install.tar.gz /