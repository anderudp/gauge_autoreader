{
    "python.autoComplete.extraPaths": [
        "/opt/ros/jazzy/lib/python3.12/site-packages",
        "${workspaceFolder}/install/gar_interfaces/lib/python3.12/site-packages"
    ],
    "python.analysis.extraPaths": [
        "/opt/ros/jazzy/lib/python3.12/site-packages",
        "${workspaceFolder}/install/gar_interfaces/lib/python3.12/site-packages"
    ],
    "terminal.integrated.profiles.linux": {
        "ros2": {
            "path": "/bin/bash",
            "args": ["--rcfile", "${workspaceFolder}/.vscode/source_ros2.sh"],
            "env": {
                "ROS_WORKSPACE": "${workspaceFolder}"
            }
        }
    },
    "terminal.integrated.defaultProfile.linux": "ros2",
    "terminal.integrated.shellIntegration.enabled": true
}
